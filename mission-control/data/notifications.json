{
  "mainTaskCompletionDiscord": {
    "enabled": true,
    "scope": "main-agent-only",
    "trigger": "When main finishes a task assigned directly by haolun in the main direct-chat session and the task is actually complete.",
    "closeoutPolicy": {
      "helper": "scripts/main_task_closeout.py",
      "ledgerFile": "mission-control/data/main-task-closeouts.json",
      "bestEffort": true,
      "blocksTaskClosure": false,
      "missedPingTolerance": "acceptable",
      "resolutionBranches": [
        "best-effort-send-requested",
        "best-effort-send-failed",
        "not-applicable",
        "blocked-or-deferred-with-reason"
      ]
    },
    "doNotSendFor": [
      "subagent-only completions",
      "partial progress updates",
      "background upkeep not directly assigned by haolun"
    ],
    "delivery": {
      "mode": "cron-announce",
      "bestEffort": true,
      "channel": "discord",
      "to": "channel:1487645227421536327",
      "currentChannelLabel": "#main_updates",
      "desiredServer": "hzwp",
      "desiredChannel": "#main_updates",
      "status": "active-main_updates-channel-tested",
      "fallbackTo": "channel:1485016833819021495",
      "fallbackChannelLabel": "#control-center",
      "fallbackPolicy": "manual-only"
    },
    "mention": "<@1049450008505757706>",
    "format": {
      "style": "one short line",
      "mustInclude": [
        "mention haolun",
        "done/finished signal",
        "extremely brief analogy",
        "pointer that the full report is in the control UI"
      ],
      "template": "<@1049450008505757706> hazoc finished: {very_short_result}. Like {tiny_analogy}. Full report is in the control UI.",
      "tone": "brief, useful, no extra chatter"
    },
    "implementation": {
      "tool": "cron",
      "pattern": "Use `scripts/main_task_closeout.py` to append a local closeout ledger entry and enqueue one lightweight one-shot isolated announce job. Do not keep a persistent recovery worker or automatic retry loop; if the ping is missed, accept the miss and move on.",
      "cronShape": {
        "schedule": "one-shot + auto-delete",
        "sessionTarget": "isolated",
        "lightContext": true,
        "thinking": "minimal",
        "wakeMode": "now",
        "delivery": "announce",
        "bestEffort": true
      },
      "tested": true,
      "lastVerifiedAt": "2026-04-02T22:59:09.000Z"
    }
  }
}
