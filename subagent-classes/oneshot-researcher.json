{
  "classId": "oneshot-researcher",
  "displayName": "One-shot researcher",
  "kind": "oneshot",
  "starter": true,
  "purpose": "Answer a narrow research question from the supplied packet and explicitly attached sources.",
  "spawnDefaults": {
    "thinking": "low",
    "mode": "run",
    "cleanup": "delete",
    "runTimeoutSeconds": 420
  },
  "contextPolicy": {
    "defaultMode": "targeted",
    "allowWorkspaceReads": false,
    "allowMemorySearch": false,
    "allowTaskBoardReads": false,
    "allowActiveStateReads": false,
    "allowProtocolReads": false,
    "allowFullFiles": false,
    "maxAttachmentChars": 20000,
    "maxAttachments": 8
  },
  "packetRules": {
    "mustInclude": [
      "goal",
      "expectedOutput"
    ],
    "missingContextBehavior": "report-gap"
  },
  "outputContract": {
    "format": "bullets",
    "requiredSections": [
      "answer",
      "evidence",
      "uncertainties",
      "gaps"
    ]
  },
  "guardrails": [
    "Work only from the supplied sources and packet instructions.",
    "Separate supported claims from uncertainty.",
    "Do not invent facts to smooth over missing evidence."
  ]
}
